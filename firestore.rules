rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - email: string (required)
    //   - isAdmin: boolean (required)
    //   - avatar: string (optional)
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - price: string (required)
    //   - shipping: string (required)
    //   - unit: string (required)
    //   - tag: string (optional)
    //   - tagColor: string (optional)
    //   - image: string (required)
    //   - createdAt: number (optional)
    //   - updatedAt: number (optional)
    //
    // Collection: notifications
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - title: string (required)
    //   - message: string (required)
    //   - read: boolean (required)
    //   - createdAt: number (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isMainAdmin() {
      return isAuthenticated() && request.auth.token.email == "marcossilva192024@gmail.com";
    }

    function isAdmin() {
      return isMainAdmin() || (
        isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.isAdmin is bool &&
             (!('isSupport' in data) || data.isSupport is bool) &&
             (!('avatar' in data) || (data.avatar is string && data.avatar.size() < 2000));
    }

    function isValidChat(data) {
      return data.participants is list && data.participants.size() == 2 &&
             data.participants[0] is string && data.participants[1] is string &&
             (!('lastMessage' in data) || (data.lastMessage is string && data.lastMessage.size() < 1000)) &&
             (!('lastMessageTime' in data) || data.lastMessageTime is number) &&
             (!('unreadCount' in data) || data.unreadCount is map) &&
             data.updatedAt is number;
    }

    function isValidMessage(data) {
      return data.chatId is string && data.chatId.size() > 0 && data.chatId.size() < 100 &&
             data.senderId is string && data.senderId.size() > 0 && data.senderId.size() < 100 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.createdAt is number;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is string && data.price.size() > 0 && data.price.size() < 50 &&
             data.shipping is string && data.shipping.size() > 0 && data.shipping.size() < 50 &&
             data.unit is string && data.unit.size() > 0 && data.unit.size() < 50 &&
             data.image is string && data.image.size() > 0 && data.image.size() < 5000000 && // Allowing large strings for base64/blob
             (!('tag' in data) || (data.tag is string && data.tag.size() < 50)) &&
             (!('tagColor' in data) || (data.tagColor is string && data.tagColor.size() < 50)) &&
             (!('createdAt' in data) || data.createdAt is number) &&
             (!('updatedAt' in data) || data.updatedAt is number) &&
             (!('createdBy' in data) || (data.createdBy is string && data.createdBy.size() < 100));
    }

    function isValidNotification(data) {
      return data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 500 &&
             data.read is bool &&
             data.createdAt is number;
    }

    match /{path=**}/products/{productId} {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || 
                     isAdmin() || 
                     resource.data.isSupport == true || 
                     (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSupport == true); // Allow reading support users, and allow support users to read all users
      
      allow create: if isAuthenticated() && 
                    isOwner(userId) && 
                    isValidUser(request.resource.data) && 
                    hasOnlyAllowedFields(['uid', 'name', 'email', 'isAdmin', 'isSupport', 'avatar']) &&
                    (request.resource.data.isAdmin == false || isMainAdmin()) &&
                    (!('isSupport' in request.resource.data) || request.resource.data.isSupport == false || isMainAdmin());
                    
      allow update: if isAuthenticated() && 
                    isValidUser(request.resource.data) && 
                    hasOnlyAllowedFields(['uid', 'name', 'email', 'isAdmin', 'isSupport', 'avatar']) &&
                    request.resource.data.uid == resource.data.uid &&
                    (
                      isMainAdmin() || 
                      (isOwner(userId) && request.resource.data.isAdmin == resource.data.isAdmin && (!('isSupport' in request.resource.data) || request.resource.data.isSupport == resource.data.isSupport))
                    );
                    
      allow delete: if isMainAdmin();

      match /products/{productId} {
        allow create: if isOwner(userId) && 
                      isValidProduct(request.resource.data) &&
                      hasOnlyAllowedFields(['name', 'price', 'shipping', 'unit', 'tag', 'tagColor', 'image', 'createdAt', 'updatedAt', 'createdBy']) &&
                      request.resource.data.createdBy == request.auth.uid;
                      
        allow update: if isOwner(userId) && 
                      isValidProduct(request.resource.data) &&
                      hasOnlyAllowedFields(['name', 'price', 'shipping', 'unit', 'tag', 'tagColor', 'image', 'createdAt', 'updatedAt', 'createdBy']) &&
                      (!('createdAt' in request.resource.data) || request.resource.data.createdAt == resource.data.createdAt) &&
                      (!('createdBy' in request.resource.data) || request.resource.data.createdBy == resource.data.createdBy);
                      
        allow delete: if isOwner(userId);
      }
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && 
                    request.auth.uid in request.resource.data.participants &&
                    isValidChat(request.resource.data) &&
                    hasOnlyAllowedFields(['participants', 'lastMessage', 'lastMessageTime', 'updatedAt', 'unreadCount']);
      allow update: if isAuthenticated() && 
                    request.auth.uid in resource.data.participants &&
                    isValidChat(request.resource.data) &&
                    hasOnlyAllowedFields(['participants', 'lastMessage', 'lastMessageTime', 'updatedAt', 'unreadCount']);
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      allow create: if isAuthenticated() && 
                    request.auth.uid == request.resource.data.senderId &&
                    request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                    isValidMessage(request.resource.data) &&
                    hasOnlyAllowedFields(['chatId', 'senderId', 'text', 'createdAt']);
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin() && 
                    isValidNotification(request.resource.data) && 
                    hasOnlyAllowedFields(['userId', 'title', 'message', 'read', 'createdAt']);
      allow update: if isAuthenticated() && 
                    resource.data.userId == request.auth.uid && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }


  }
}
